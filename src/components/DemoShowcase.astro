---
// DemoShowcase.astro
---
<section id="showcase" class="py-32 bg-primary relative border-t border-quaternary border-b overflow-hidden">
  
  <div class="absolute left-0 top-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-secondary/10 blur-[150px] rounded-full z-0 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 text-center">
    
    <div class="mb-20 space-y-4">
      <h2 class="text-4xl md:text-5xl font-extrabold text-theme-white tracking-tight">El estándar que tus compradores esperan</h2>
      <p class="text-xl text-secondary max-w-2xl mx-auto">Una experiencia de compra a la altura del desarrollo que estás construyendo.</p>
    </div>

    <!-- UI Mockups or interactive looking elements -->
    <div class="relative w-full aspect-3/4 md:aspect-video bg-primary rounded-3xl border border-quaternary/50 shadow-2xl shadow-theme-white/10 overflow-hidden flex flex-col group">
      <!-- Browser chrome -->
      <div class="h-12 w-full bg-quaternary/80 border-b border-quaternary/50 flex items-center px-4 gap-2 backdrop-blur-md">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
        <div class="mx-auto w-1/3 h-6 bg-primary rounded text-[10px] text-secondary flex items-center justify-center font-mono">realspacehub.com/demo</div>
      </div>
      
      <!-- Fake App Content -->
      <div class="flex-1 w-full bg-primary flex p-6 gap-6 relative">
       <iframe src="https://real-space.netlify.app/virtual-tour" class="w-full h-full scroll-smooth"></iframe> 
      </div>
    </div>
  </div>
</section>
