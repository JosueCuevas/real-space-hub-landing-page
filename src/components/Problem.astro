---
// Problem.astro
const problems = [
  {
    title: "Cotizaciones manuales lentas",
    description: "Cada presupuesto requiere cruzar emails, Excels, calcular enganches y esperar aprobaciones.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />`
  },
  {
    title: "PDFs desactualizados",
    description: "Enviar un listado de unidades disponibles es obsoleto en minutos, causando vender la misma propiedad dos veces.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />`
  },
  {
    title: "Clientes confundidos",
    description: "Compradores y asesores no tienen claridad visual de cuál unidad están comprando ni su ubicación real.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />`
  },
  {
    title: "Pérdida de oportunidades",
    description: "La fricción en la información genera caídas en cierres. La falta de impacto visual reduce el valor percibido.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />`
  }
];
---
<section id="problema" class="py-24 bg-primary border-t border-quaternary/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-tertiary font-semibold tracking-wide uppercase text-sm mb-3">El dolor del desarrollador</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-theme-white sm:text-4xl">
        Las ventas inmobiliarias están frenadas por procesos análogos y manuales.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {problems.map(problem => (
        <div class="bg-quaternary/20 border border-quaternary/50 focus-within:border-tertiary/50 rounded-2xl p-8 hover:bg-quaternary/40 transition shadow-lg group">
          <div class="h-12 w-12 rounded-xl bg-quaternary/50 flex items-center justify-center border border-quaternary group-hover:bg-tertiary/20 group-hover:border-tertiary/50 transition">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-secondary group-hover:text-theme-white transition" set:html={problem.icon}></svg>
          </div>
          <h3 class="mt-6 text-xl font-semibold text-theme-white">{problem.title}</h3>
          <p class="mt-3 text-secondary leading-relaxed text-lg">{problem.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
