---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Recuerda cambiar este correo por el tuyo en FormSubmit
const FORMSUBMIT_EMAIL = "ventas@realspacehub.com";
---

<MainLayout 
  title="Solicitar cotización | Real Space Hub" 
  description="Cuéntanos sobre tu desarrollo inmobiliario para prepararte una propuesta personalizada con Real Space Hub."
>
  <Header />
  
  <main class="pt-24 pb-16 min-h-screen bg-gray-50 flex flex-col justify-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      
      <div class="text-center mb-10">
        <h1 class="text-4xl font-extrabold text-primary tracking-tight mb-4">
          Solicita una propuesta
        </h1>
        <p class="text-lg text-quaternary max-w-2xl mx-auto">
          Cuéntanos sobre tu proyecto inmobiliario. Esta información nos ayudará a preparar una demostración y cotización adaptada exactamente a lo que necesitas.
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow-xl overflow-hidden max-w-3xl mx-auto border border-gray-100 p-8 sm:p-10">
        
        <form action={`https://formsubmit.co/${FORMSUBMIT_EMAIL}`} method="POST" class="space-y-6">
          
          <!-- Configuracion FormSubmit -->
          <!-- Deshabilita el reCAPTCHA por defecto si prefieres (opcional) -->
          <input type="hidden" name="_captcha" value="false">
          <!-- Página a la que redirige al enviar (puedes crear una página /gracias luego) -->
          <!-- <input type="hidden" name="_next" value="https://realspacehub.com/thanks"> -->
          <input type="hidden" name="_next" value="http://localhost:4321/thanks">
          <!-- Asunto del correo -->
          <input type="hidden" name="_subject" value="Nuevo Lead de Cotización - Real Space Hub">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Nombre -->
            <div>
              <label for="name" class="block text-sm font-medium text-primary mb-1">Nombre completo *</label>
              <input type="text" name="name" id="name" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors text-primary"
                placeholder="Juan Pérez">
            </div>

            <!-- Empresa -->
            <div>
              <label for="company" class="block text-sm font-medium text-primary mb-1">Empresa / Desarrolladora *</label>
              <input type="text" name="company" id="company" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors text-primary"
                placeholder="Inmobiliaria XYZ">
            </div>

            <!-- Correo -->
            <div>
              <label for="email" class="block text-sm font-medium text-primary mb-1">Email profesional *</label>
              <input type="email" name="email" id="email" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors text-primary"
                placeholder="hola@empresa.com">
            </div>

            <!-- Teléfono -->
            <div>
              <label for="phone" class="block text-sm font-medium text-primary mb-1">Teléfono *</label>
              <input type="tel" name="phone" id="phone" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors text-primary"
                placeholder="+52 55 1234 5678">
            </div>

            <!-- Ciudad del desarrollo -->
            <div>
              <label for="city" class="block text-sm font-medium text-primary mb-1">Ciudad del desarrollo *</label>
              <input type="text" name="city" id="city" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors text-primary"
                placeholder="Ciudad de México, Monterrey, etc.">
            </div>

            <!-- Número de unidades -->
            <div>
              <label for="units" class="block text-sm font-medium text-primary mb-1">Número de unidades *</label>
              <select name="units" id="units" required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors text-primary">
                <option value="" disabled selected>Selecciona un rango</option>
                <option value="1-10">1 a 10 unidades</option>
                <option value="11-50">11 a 50 unidades</option>
                <option value="51-150">51 a 150 unidades</option>
                <option value="150+">Más de 150 unidades</option>
              </select>
            </div>
          </div>

          <!-- Etapa del proyecto -->
          <div class="pt-4 border-t border-gray-100">
            <span class="block text-sm font-medium text-primary mb-3">Etapa actual del proyecto *</span>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              
              <label class="relative flex cursor-pointer rounded-lg border bg-white p-4 shadow-sm focus:outline-none has-checked:border-secondary has-checked:ring-1 has-checked:ring-secondary hover:bg-gray-50 transition-colors">
                <input type="radio" name="stage" value="Preventa" class="sr-only" required>
                <span class="flex flex-1">
                  <span class="flex flex-col">
                    <span class="block text-sm font-medium text-primary">Preventa</span>
                    <span class="mt-1 flex items-center text-sm text-quaternary">Aún sin construir</span>
                  </span>
                </span>
                <span class="pointer-events-none absolute -inset-px rounded-lg border-2 border-transparent" aria-hidden="true"></span>
              </label>

              <label class="relative flex cursor-pointer rounded-lg border bg-white p-4 shadow-sm focus:outline-none has-checked:border-secondary has-checked:ring-1 has-checked:ring-secondary hover:bg-gray-50 transition-colors">
                <input type="radio" name="stage" value="Construcción" class="sr-only">
                <span class="flex flex-1">
                  <span class="flex flex-col">
                    <span class="block text-sm font-medium text-primary">Construcción</span>
                    <span class="mt-1 flex items-center text-sm text-quaternary">En obra activa</span>
                  </span>
                </span>
                <span class="pointer-events-none absolute -inset-px rounded-lg border-2 border-transparent" aria-hidden="true"></span>
              </label>

              <label class="relative flex cursor-pointer rounded-lg border bg-white p-4 shadow-sm focus:outline-none has-checked:border-secondary has-checked:ring-1 has-checked:ring-secondary hover:bg-gray-50 transition-colors">
                <input type="radio" name="stage" value="Terminado" class="sr-only">
                <span class="flex flex-1">
                  <span class="flex flex-col">
                    <span class="block text-sm font-medium text-primary">Terminado</span>
                    <span class="mt-1 flex items-center text-sm text-quaternary">Listo para entrega</span>
                  </span>
                </span>
                <span class="pointer-events-none absolute -inset-px rounded-lg border-2 border-transparent" aria-hidden="true"></span>
              </label>
            </div>
          </div>

          <!-- Mensaje -->
          <div class="pt-4 border-t border-gray-100">
            <label for="message" class="block text-sm font-medium text-primary mb-1">Cuéntanos más sobre el proyecto (Opcional)</label>
            <textarea name="message" id="message" rows="4"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors resize-y text-primary"
              placeholder="Ej. Buscamos mostrar los amenitites principales, tenemos renders básicos, etc."></textarea>
          </div>

          <!-- Botón Enviar -->
          <div class="pt-4">
            <button type="submit" 
              class="w-full sm:w-auto px-8 py-4 hover:border border-secondary bg-theme-white hover:bg-quaternary hover:text-white text-primary font-bold text-lg rounded-xl transition-all shadow-[0_0_40px_rgba(255,255,255,0.15)] hover:shadow-[0_0_60px_rgba(255,255,255,0.25)] transform hover:-translate-y-1 flex items-center justify-center gap-2 group mx-auto cursor-pointer">
              👉 Solicitar propuesta
            </button>
            <p class="text-xs text-center text-gray-500 mt-4">
              Al enviar este formulario aceptas que te contactemos para enviarte información. No compartimos tus datos.
            </p>
          </div>

        </form>

      </div>
    </div>
  </main>

  <Footer />
</MainLayout>
