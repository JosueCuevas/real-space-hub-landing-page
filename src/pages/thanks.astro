---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout 
  title="Gracias por contactarnos | Real Space Hub" 
  description="Hemos recibido tu información. Nos pondremos en contacto contigo lo más pronto posible."
>
  <Header />
  
  <main class="pt-32 pb-24 min-h-[80vh] bg-gray-50 flex flex-col justify-center items-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 w-full text-center">
      
      <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100 p-12 relative">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 -mx-6 -my-6 w-32 h-32 bg-green-50 rounded-full blur-2xl"></div>
        <div class="absolute bottom-0 left-0 -mx-6 -my-6 w-32 h-32 bg-blue-50 rounded-full blur-2xl"></div>
        
        <div class="relative z-10 flex flex-col items-center">
          <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mb-8 shadow-sm">
            <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>

          <h1 class="text-4xl font-extrabold text-primary tracking-tight mb-4">
            ¡Mensaje recibido!
          </h1>
          
          <p class="text-xl text-quaternary mb-10 max-w-lg mx-auto">
            Gracias por tu interés en Real Space Hub. Un especialista de nuestro equipo revisará tu información y se pondrá en contacto contigo <span class="font-semibold text-primary">lo más pronto posible</span>.
          </p>

          <a href="/" class="inline-flex items-center px-8 py-4 bg-primary hover:bg-quaternary text-white font-bold rounded-xl transition-all shadow-[0_4px_14px_0_rgba(0,0,0,0.2)] hover:shadow-[0_6px_20px_rgba(0,0,0,0.23)] hover:-translate-y-1">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Volver al inicio
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</MainLayout>
